rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow reads if the user is authenticated and is reading their own document.
    // Writes are strictly denied from the client. Cloud Functions bypass these rules.
    match /saves/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
